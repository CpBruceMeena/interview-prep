<mxfile host="Electron" agent="Codebuff">
  <diagram name="Car Rental Platform Class Diagram" id="car-rental-class-diagram">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Car Rental Platform — Class Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- Vehicle -->
        <mxCell id="vehicle" value="&lt;b&gt;Vehicle&lt;/b&gt;&lt;hr&gt;- _vehicle_id: str&lt;br&gt;- _make: str&lt;br&gt;- _model: str&lt;br&gt;- _type: VehicleType&lt;br&gt;- _location: str&lt;br&gt;- _daily_rate: float" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="220" height="140" as="geometry"/>
        </mxCell>

        <!-- TimeBlock -->
        <mxCell id="timeblock" value="&lt;b&gt;TimeBlock&lt;/b&gt;&lt;hr&gt;- start: datetime&lt;br&gt;- end: datetime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#8BC34A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="80" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- AvailabilityCalendar (Core) -->
        <mxCell id="calendar" value="&lt;b&gt;⭐ AvailabilityCalendar&lt;/b&gt;&lt;hr&gt;- _booked_slots: Dict[str, Set[int]]&lt;br&gt;  (vehicle_id → set of hours)&lt;hr&gt;+ is_available(id, pickup, dropoff) → bool&lt;br&gt;+ mark_booked(id, pickup, dropoff)&lt;br&gt;+ get_availability_summary(id, date)&lt;br&gt;+ get_weekly_availability(id, start)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#FBC02D;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="290" width="260" height="170" as="geometry"/>
        </mxCell>

        <!-- Reservation -->
        <mxCell id="reservation" value="&lt;b&gt;Reservation&lt;/b&gt;&lt;hr&gt;- _reservation_id: str&lt;br&gt;- _vehicle: Vehicle&lt;br&gt;- _customer_id: str&lt;br&gt;- _pickup/dropoff: datetime&lt;br&gt;- _total_price: float&lt;br&gt;- _status: ReservationStatus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="300" width="240" height="160" as="geometry"/>
        </mxCell>

        <!-- PricingStrategy -->
        <mxCell id="price_abs" value="&lt;b&gt;&amp;lt;&amp;lt;Strategy&amp;gt;&amp;gt;&lt;/b&gt;&lt;br&gt;&lt;b&gt;PricingStrategy&lt;/b&gt;&lt;hr&gt;&lt;i&gt;+ calculate_price(pickup, dropoff) → float&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="520" width="210" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="hourly" value="&lt;b&gt;HourlyPricing&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#9C27B0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="520" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="daily" value="&lt;b&gt;DailyPricing&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#9C27B0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="520" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="discount" value="&lt;b&gt;WeeklyDiscountPricing&lt;/b&gt;&lt;br&gt;(Decorator: 15% off weekly)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#9C27B0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="590" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- SearchService -->
        <mxCell id="search" value="&lt;b&gt;SearchService&lt;/b&gt;&lt;hr&gt;+ search_available(pickup, dropoff, type, loc)&lt;br&gt;+ browse_weekly(type, location)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#2196F3;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="670" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- CarRentalService (Facade) -->
        <mxCell id="service" value="&lt;b&gt;&amp;lt;&amp;lt;Facade&amp;gt;&amp;gt;&lt;/b&gt;&lt;br&gt;&lt;b&gt;CarRentalService&lt;/b&gt;&lt;hr&gt;- _vehicles: Dict[str, Vehicle]&lt;br&gt;- _calendar: AvailabilityCalendar&lt;br&gt;- _pricing: PricingStrategy&lt;br&gt;- _search: SearchService&lt;hr&gt;+ create_reservation() → Reservation&lt;br&gt;+ cancel_reservation()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="820" width="260" height="180" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="core" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FBC02D;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="calendar" target="vehicle"/>
        <mxCell id="e2" value="uses" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E91E63;strokeWidth=1;dashed=1;fontSize=10;" edge="1" parent="1" source="reservation" target="vehicle"/>
        <mxCell id="e3" value="checks" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E91E63;strokeWidth=1;dashed=1;fontSize=10;" edge="1" parent="1" source="reservation" target="calendar"/>
        <mxCell id="e4" value="&amp;lt;&amp;lt;extends&amp;gt;&amp;gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9C27B0;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="price_abs" target="hourly"/>
        <mxCell id="e5" value="&amp;lt;&amp;lt;extends&amp;gt;&amp;gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9C27B0;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="price_abs" target="daily"/>
        <mxCell id="e6" value="wraps" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9C27B0;strokeWidth=2;dashed=1;fontSize=10;" edge="1" parent="1" source="discount" target="daily"/>
        <mxCell id="e7" value="uses" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1565C0;strokeWidth=1;dashed=1;fontSize=10;" edge="1" parent="1" source="service" target="calendar"/>
        <mxCell id="e8" value="uses" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1565C0;strokeWidth=1;dashed=1;fontSize=10;" edge="1" parent="1" source="service" target="search"/>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>