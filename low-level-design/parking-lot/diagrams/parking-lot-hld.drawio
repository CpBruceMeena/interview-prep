        <!-- ======== ARCHITECTURE NOTES ======== -->
        <mxCell id="note-resilience" value="Resilience Notes:&#xa;• Circuit breaker: DDB fail → fall back to Aurora (300ms)&#xa;• Retry: exponential backoff with jitter (base 100ms × 2^n)&#xa;• Payment idempotency: ON CONFLICT DO NOTHING + Redis (48h TTL)&#xa;• DLQ: redrive up to 3x, dead-letter to S3, alert if >10 in DLQ >1h" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#FFF8C5;strokeColor=#D4A72C;fontSize=9;fontColor=#24292F;align=left;spacingLeft=4;" vertex="1" parent="1">
