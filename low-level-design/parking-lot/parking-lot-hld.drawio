        </mxCell>

        <!-- SQS → DLQ -->
        <mxCell id="e-sqs-dlq" value="redrive on failure" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ef4444;strokeWidth=1;fontSize=9;fontColor=#ef4444;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="sqs-cell" target="dlq-cell">
