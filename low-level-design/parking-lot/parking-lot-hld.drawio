          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================= -->
        <!-- EDGES: COMPUTE → MESSAGING                     -->
        <!-- ============================================= -->
        <!-- Lambda Entry → Kinesis -->
        <mxCell id="e-entry-kds" value="writes events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4ade80;strokeWidth=2;fontSize=9;fontColor=#4ade80;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lambda-entry-cell" target="kds-cell">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Lambda Exit → SQS -->
        <mxCell id="e-exit-sqs" value="enqueues payment" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4ade80;strokeWidth=2;fontSize=9;fontColor=#4ade80;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lambda-exit-cell" target="sqs-cell">
