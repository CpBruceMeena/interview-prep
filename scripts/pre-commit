#!/bin/bash

# Pre-commit hook: prevent direct commits to the main branch.
# All changes to main must go through a pull request on GitHub.
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

protected_branch="main"
current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"

if [[ "$current_branch" == "$protected_branch" ]]; then
    echo "🚫 ERROR: Committing directly to '$protected_branch' is not allowed!"
    echo "   Please create a feature branch and use a pull request instead."
    echo "   Branch protection requires PR review before merging to $protected_branch."
    exit 1
fi

exit 0
